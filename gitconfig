# vim: ft=gitconfig
[include]
    path = ~/.gitconfig_local
[user]
    name = Mark Harviston
[push]
    default = current
[pull]
    rebase = true
[cola]
    spellcheck = false
[core]
    editor = vim
    excludesFile = ~/.gitignore_global
    attributesfile = ~/.gitattributes
[alias]
    autosquash = git rebase -i master --autosquash
    ppush = push --force-with-lease
    bbranch = branch --sort=-committerdate
    stashgrep = "!f() { for i in `git stash list --format=\"%gd\"` ; \
                 do git stash show -p $i | grep -H --label=\"$i\" \"$@\" ; done ; }; f"
[init]
    defaultBranch = master
[pull]
	rebase = true
